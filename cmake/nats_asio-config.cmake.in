@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(fmt CONFIG)
find_dependency(nlohmann_json CONFIG)
find_dependency(simdjson CONFIG)
find_dependency(spdlog CONFIG)
find_dependency(asio CONFIG)
find_dependency(magic_enum CONFIG)
find_dependency(zstd CONFIG)
find_dependency(OpenSSL)
find_dependency(ZLIB)
find_dependency(libzip CONFIG)

find_path(NATS_ASIO_CONCURRENTQUEUE_INCLUDE_DIR
    NAMES concurrentqueue/moodycamel/concurrentqueue.h REQUIRED)
find_path(NATS_ASIO_GTL_INCLUDE_DIR NAMES gtl/lru_cache.hpp REQUIRED)
find_path(NATS_ASIO_STRINGZILLA_INCLUDE_DIR
    NAMES stringzilla/stringzilla.hpp REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/nats_asio-targets.cmake")

set_property(TARGET nats_asio::nats_asio APPEND PROPERTY
    INTERFACE_INCLUDE_DIRECTORIES
    "${NATS_ASIO_CONCURRENTQUEUE_INCLUDE_DIR}"
    "${NATS_ASIO_GTL_INCLUDE_DIR}"
    "${NATS_ASIO_STRINGZILLA_INCLUDE_DIR}"
)

check_required_components(nats_asio)
